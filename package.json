{
  "name": "1-github-finder",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "prebuild": "node generate-build-version",
    "build": "npm run prebuild && vite build",
    "generate-build-version": "node generate-build-version",
    "release-patch": "npm version patch && npm run postversion",
    "release-minor": "npm version minor && npm run postversion",
    "release-major": "npm version major && npm run postversion",
    "postversion": "npm run build && npm run git-script",
    "git-script": "node git-script",
    "deploy": "./deploy.sh"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "vite": "^8.0.11"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0"
  }
}
